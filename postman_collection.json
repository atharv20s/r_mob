{
  "info": {
    "name": "Route Mobile Enterprise API",
    "_postman_id": "rm-enterprise-2026",
    "description": "Enterprise AI Gateway with Redis-backed rate limiting, caching, sessions, quotas, and JWT blacklisting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "{{base_url}}", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api","v1","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@route.com\",\n  \"password\": \"TestPassword123!\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.environment.set('access_token', json.access_token);",
                  "  pm.environment.set('refresh_token', json.refresh_token);",
                  "}",
                  "pm.test('Login returns 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api","v1","auth","login"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "admin@route.com" },
                { "key": "password", "value": "adminpassword" }
              ]
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.environment.set('admin_token', json.access_token);",
                  "}",
                  "pm.test('Admin login returns 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api","v1","auth","login"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "admin@route.com" },
                { "key": "password", "value": "adminpassword" }
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["api","v1","auth","refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Auth Check",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/check", "host": ["{{base_url}}"], "path": ["api","v1","auth","check"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/logout", "host": ["{{base_url}}"], "path": ["api","v1","auth","logout"] }
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Chat Completion",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Chat returns 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has cached field', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.have.property('cached');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/chat", "host": ["{{base_url}}"], "path": ["api","v1","chat"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Explain quantum computing in one sentence.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Usage",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/usage/me", "host": ["{{base_url}}"], "path": ["api","v1","usage","me"] }
          }
        },
        {
          "name": "Get Usage",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/usage/usage", "host": ["{{base_url}}"], "path": ["api","v1","usage","usage"] }
          }
        }
      ]
    },
    {
      "name": "Session",
      "item": [
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/me/session", "host": ["{{base_url}}"], "path": ["api","v1","me","session"] }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Redis Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Redis is connected', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.redis).to.eql('connected');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/health/redis", "host": ["{{base_url}}"], "path": ["api","v1","health","redis"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Cache Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/admin/cache/stats", "host": ["{{base_url}}"], "path": ["api","v1","admin","cache","stats"] }
          }
        },
        {
          "name": "Rate Limit Metrics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/admin/redis/rate-limit", "host": ["{{base_url}}"], "path": ["api","v1","admin","redis","rate-limit"] }
          }
        },
        {
          "name": "Redis Key Inspection",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/admin/redis/keys", "host": ["{{base_url}}"], "path": ["api","v1","admin","redis","keys"] }
          }
        }
      ]
    }
  ]
}
