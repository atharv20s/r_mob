# FastAPI Settings
PROJECT_NAME="Route Mobile API"
API_V1_STR="/api/v1"
DEBUG=true

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your_s3_bucket_name

# AI Configuration (Gemini / OpenAI / Mistral)
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
DEFAULT_MODEL=gemini-1.5-flash

# Mistral Configuration
MISTRAL_API_KEY=your_mistral_api_key

# PostgreSQL Database (accessed via SQLAlchemy ORM)
# Production:  postgresql+psycopg2://admin:password@localhost:5432/ai_gateway
# Local dev:   sqlite:///./route_mobile.db
DATABASE_URL=postgresql+psycopg2://admin:password@localhost:5432/ai_gateway
REDIS_URL=redis://localhost:6379

# JWT Auth Settings
JWT_SECRET=your_random_256_bit_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
